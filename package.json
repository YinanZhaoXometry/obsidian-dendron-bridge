{
  "name": "dendron-bridge",
  "version": "0.0.1",
  "description": "An Obsidian plugin that brings Dendron-style hierarchical note management (dot-separated naming, fuzzy lookup, auto frontmatter, multi-vault) to Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc -noEmit -skipLibCheck && vite build",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "jest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@types/jest": "^29.5.2",
    "@types/node": "^18.19.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "@vitejs/plugin-react": "^4.3.1",
    "builtin-modules": "3.3.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.7.0",
    "obsidian": "latest",
    "prettier": "^3.3.3",
    "ts-jest": "^29.1.0",
    "tslib": "2.4.0",
    "typescript": "4.7.4",
    "vite": "^5.4.2"
  },
  "dependencies": {
    "@codemirror/language": "https://github.com/lishid/cm-language",
    "@codemirror/state": "^6.2.1",
    "@codemirror/view": "^6.13.0",
    "fuse.js": "^7.0.0",
    "github-slugger": "^2.0.0",
    "nanoid": "^4.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0"
  }
}
